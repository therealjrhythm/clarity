# =========================================================
# Clarity .gitignore
# Next.js + TypeScript + Supabase + Vercel + AI app
# =========================================================


# -------------------------
# Dependencies
# -------------------------
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions


# -------------------------
# Next.js build output
# -------------------------
.next/
out/
build/
dist/


# -------------------------
# Production / generated output
# -------------------------
.vercel/
.turbo/
.swc/
.cache/
.parcel-cache/


# -------------------------
# Testing / coverage
# -------------------------
coverage/
.nyc_output/
playwright-report/
test-results/


# -------------------------
# Logs
# -------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# -------------------------
# Environment variables / secrets
# NEVER commit real API keys
# -------------------------
.env
.env.*
!.env.example
!.env.template


# -------------------------
# Supabase local files
# Keep supabase/migrations committed.
# Keep supabase/config.toml committed unless you have a reason not to.
# -------------------------
supabase/.temp/
supabase/.branches/
supabase/.env


# -------------------------
# Local generated Clarity artifacts
# These should not become source-controlled app code.
# Store real exports in Supabase Storage or attach them manually when needed.
# -------------------------
.clarity/
/clarity/
/clarity 2/
generated/
exports/
artifacts/
tmp/
temp/


# -------------------------
# TypeScript
# -------------------------
*.tsbuildinfo
next-env.d.ts


# -------------------------
# OS files
# -------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini


# -------------------------
# Editor / IDE
# -------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.idea/
*.sublime-project
*.sublime-workspace


# -------------------------
# Certificates / private keys
# -------------------------
*.pem
*.key
*.crt
*.p12
*.pfx


# -------------------------
# Misc
# -------------------------
*.tgz
*.zip
